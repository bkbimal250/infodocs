# -----------------------------
# Application Settings
# -----------------------------
APP_NAME=infodocs API
# CRITICAL: Set to False in production
DEBUG=False
HOST=0.0.0.0
PORT=8009

# -----------------------------
# Security / Auth
# -----------------------------
# CRITICAL: Generate a new secure key (at least 64 chars)
SECRET_KEY=CHANGE_THIS_TO_A_REAL_SECURE_RANDOM_STRING_AT_LEAST_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# -----------------------------
# MySQL Database Settings
# -----------------------------
DB_NAME=spadocs
DB_USER=dosadmin
DB_PASSWORD=your_secure_db_password
DB_HOST=82.25.109.137
DB_PORT=3306

# -----------------------------
# CORS
# -----------------------------
# Comma-separated list of allowed origins. NO trailing slashes.
CORS_ORIGINS=https://docs.dishaonlinesoution.in,https://infodocs.api.d0s369.co.in

# -----------------------------
# File Uploads
# -----------------------------
MAX_UPLOAD_SIZE=524288000  # 500 MB
# Absolute path strongly recommended for production
UPLOAD_DIR=/var/www/infodocs/media

# -----------------------------
# Email Settings
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=info.dishaonlinesoution@gmail.com
# Use an App Password if using Gmail
SMTP_PASSWORD=your_secure_app_password
SMTP_FROM_EMAIL=Disha Online Solution <info.dishaonlinesoution@gmail.com>
SERVER_EMAIL=info.dishaonlinesoution@gmail.com

# -----------------------------
# SMS / Phone OTP Settings
# -----------------------------
SKIP_SMS=false
SMS_API_URL=https://www.hilitemultimedia.co.in/websms/api/http/index.php
SMS_USERNAME=
SMS_API_KEY=
SMS_API_REQUEST=Text
SMS_ROUTE=ServiceImplicit
SMS_SENDER_ID=SPAADV
SMS_TEMPLATE_ID=1107177728023601932
SMS_MOBILE_PARAM=mobile
SMS_MESSAGE_PARAM=message
SMS_TEMPLATE_ID_PARAM=TemplateID
# Hilite's current SMS endpoint may fail CA-chain verification on some servers.
# Keep true when the provider certificate chain is valid; set false only for this known provider issue.
SMS_VERIFY_SSL=false
SMS_HTTP_METHOD=GET
SMS_TIMEOUT_SECONDS=20
SMS_CONNECT_TIMEOUT_SECONDS=10
SMS_MAX_RETRIES=2

# -----------------------------
# Redis (Optional but Recommended)
# -----------------------------
REDIS_URL=redis://localhost:6379/0
