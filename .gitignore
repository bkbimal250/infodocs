.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Log files
*.log
backend.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# Editor / IDE
.vscode/
.idea/
*.code-workspace
.sublime-project
.sublime-workspace


############################
# Environment files
############################

.env
.env.*
!.env.example


############################
# Python / Backend
############################

# Dependencies & Environments
venv/
.venv/
env/
ENV/
bin/
lib/
include/

# Caches
