*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# Databases
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# Project Specific
fastapi-backend/scripts_archived/
fastapi-backend/media/
fastapi-backend/uploads/


